{
  "rules": {
    "users": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('profile').child('isAdmin').val() === true",
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('profile').child('isAdmin').val() === true)",
        "profile": {
          ".read": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('profile').child('isAdmin').val() === true)",
          ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('profile').child('isAdmin').val() === true)",
          "isAdmin": {
            ".write": "auth != null && root.child('users').child(auth.uid).child('profile').child('isAdmin').val() === true"
          }
        },
        "apiKey": {
          ".read": "auth != null && auth.uid === $uid",
          ".write": "auth != null && auth.uid === $uid"
        }
      }
    },
    "chats": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('profile').child('isAdmin').val() === true",
      ".write": "auth != null && root.child('users').child(auth.uid).child('profile').child('isAdmin').val() === true",
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('profile').child('isAdmin').val() === true)",
        ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('profile').child('isAdmin').val() === true)",
        "$chatId": {
          ".read": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('profile').child('isAdmin').val() === true)",
          ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('profile').child('isAdmin').val() === true)",
          "title": {
            ".validate": "newData.isString() && newData.val().length <= 100"
          },
          "messages": {
            "$msgId": {
              ".validate": "newData.hasChildren(['role', 'content'])"
            }
          }
        }
      }
    },
    "admin": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('profile').child('isAdmin').val() === true",
      "stats": {
        ".write": "auth != null && root.child('users').child(auth.uid).child('profile').child('isAdmin').val() === true"
      },
      "systemLogs": {
        ".indexOn": [
          "timestamp"
        ],
        ".read": "auth != null && root.child('users').child(auth.uid).child('profile').child('isAdmin').val() === true",
        ".write": "auth != null && (!newData.exists() ? root.child('users').child(auth.uid).child('profile').child('isAdmin').val() === true : true)"
      }
    },

    "globalSettings": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('users').child(auth.uid).child('profile').child('isAdmin').val() === true"
    }
  }
}